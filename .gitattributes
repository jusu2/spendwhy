# 默认：自动按平台换行
* text=auto eol=lf

# 源代码：强制 LF
*.dart      text eol=lf
*.rs        text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.gradle    text eol=lf
*.kts       text eol=lf
*.kt        text eol=lf
*.java      text eol=lf
*.swift     text eol=lf
*.h         text eol=lf
*.m         text eol=lf
*.mm        text eol=lf
*.plist     text eol=lf
*.xcconfig  text eol=lf
*.sh        text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Windows 专用脚本：CRLF
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# 二进制
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.jks       binary
*.keystore  binary
*.so        binary
*.dylib     binary
*.dll       binary
*.a         binary
*.lib       binary

# 生成代码：合并时标记
lib/src/rust/**     linguist-generated=true
rust/src/frb_generated.rs linguist-generated=true
